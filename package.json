{
  "name": "@telepat-io/telepat-design-system",
  "version": "1.0.1",
  "description": "Telepat brand design system — React component library with Storybook",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/telepat-io/telepat-design-system.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./sections": {
      "types": "./dist/sections.d.ts",
      "import": "./dist/sections.js",
      "require": "./dist/sections.cjs"
    },
    "./styles.css": "./dist/styles.css",
    "./tokens.css": "./dist/tokens.css",
    "./fonts.css": "./dist/fonts.css",
    "./package.json": "./package.json"
  },
  "scripts": {
    "fetch-fonts": "node scripts/fetch-fonts.mjs",
    "predev": "npm run fetch-fonts",
    "prebuild": "npm run fetch-fonts",
    "prebuild-storybook": "npm run fetch-fonts",
    "dev": "storybook dev -p 6006",
    "build": "tsc -p tsconfig.build.json && vite build",
    "build-storybook": "storybook build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src .storybook",
    "lint:fix": "eslint src .storybook --fix",
    "preview": "vite preview"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@laynezh/vite-plugin-lib-assets": "^2.1.3",
    "@storybook/addon-a11y": "^8.4.7",
    "@storybook/addon-essentials": "^8.4.7",
    "@storybook/addon-interactions": "^8.4.7",
    "@storybook/blocks": "^8.4.7",
    "@storybook/react": "^8.4.7",
    "@storybook/react-vite": "^8.4.7",
    "@storybook/test": "^8.4.7",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.39.4",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "storybook": "^8.4.7",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.59.4",
    "vite": "^5.4.11",
    "vite-plugin-dts": "^4.3.0",
    "vite-plugin-static-copy": "^2.2.0"
  },
  "keywords": [
    "telepat",
    "design-system",
    "react",
    "storybook",
    "components",
    "ui-library"
  ],
  "license": "MIT"
}
